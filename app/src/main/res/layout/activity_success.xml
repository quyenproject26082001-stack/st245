<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_play"
    tools:context="com.temm.activity_app.main.SuccessActivity">
    >

    <ImageView
        android:id="@+id/img"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/congrat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/successTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/cherrybombone_regular"
        android:gravity="center"
        android:text="@string/success_title"
        android:textColor="@color/white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/img" />





    <FrameLayout
        android:id="@+id/btn_bg_play"
        android:layout_width="105dp"
        android:layout_height="53dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_play_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/successTitle" >

    <TextView
        android:paddingHorizontal="15dp"
        style="@style/single_marquee"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cherrybombone_regular"
        android:text="@string/play_again"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="2dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:id="@+id/play"
        />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>