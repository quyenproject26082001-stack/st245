<?xml version="1.0" encoding="utf-8"?>
<!-- Outer layout: RecyclerView item root. match_parent width so GridLayoutManager sets column width -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"

    android:layout_marginHorizontal="4dp">

    <!-- Inner layout: 0dp/0dp + ratio works here because parent IS a ConstraintLayout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="104:156"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_character"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="104:144"
            android:background="@drawable/bg_frame_item"
            />

        <TextView
            android:id="@+id/tv_use"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="88:32"
            android:background="@drawable/bg_use_character"
            android:text="@string/use"
            android:layout_marginHorizontal="8dp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/cherrybombone_regular"
            android:gravity="center" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
